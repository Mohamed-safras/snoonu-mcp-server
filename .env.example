SNOONU_DB_URL=postgresql://snoonu:snoonu@localhost:5432/snoonu_mcp
SNOONU_MCP_PORT=8000
SNOONU_MCP_TRANSPORT=streamable-http
SNOONU_MCP_WORKERS=4
SNOONU_ORDER_MAX_PER_HOUR=25

SNOONU_DB_POOL_SIZE=10
SNOONU_DB_MAX_OVERFLOW=20
SNOONU_DB_POOL_RECYCLE=1800

SNOONU_REDIS_URL=redis://localhost:6379/0

SNOONU_LOG_LEVEL=INFO
SNOONU_LOG_JSON=true

# docker-compose secret overrides (do not commit real values)
POSTGRES_PASSWORD=snoonu
PGADMIN_PASSWORD=snoonu
GRAFANA_PASSWORD=admin

# --- GCP deployment ---
# When SNOONU_GCP_PROJECT is set, SNOONU_DB_URL and SNOONU_REDIS_URL are read from
# GCP Secret Manager (latest version of a secret with that exact name) instead of
# from the environment. Create them with, e.g.:
#   gcloud secrets create SNOONU_DB_URL --replication-policy=automatic
#   echo -n "postgresql://user:pass@host:5432/db" | gcloud secrets versions add SNOONU_DB_URL --data-file=-
# The running service account needs roles/secretmanager.secretAccessor.
# SNOONU_GCP_PROJECT=my-gcp-project-id
