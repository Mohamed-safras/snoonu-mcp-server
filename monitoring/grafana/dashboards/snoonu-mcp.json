{
  "title": "Snoonu MCP Server",
  "uid": "snoonu-mcp",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(snoonu_mcp_requests_total[1m])) by (path, status)", "legendFormat": "{{path}} {{status}}" }
      ]
    },
    {
      "id": 2,
      "title": "Request latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(snoonu_mcp_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}" }
      ]
    },
    {
      "id": 3,
      "title": "Tool call rate by outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(snoonu_mcp_tool_calls_total[1m])) by (tool, outcome)", "legendFormat": "{{tool}} {{outcome}}" }
      ]
    },
    {
      "id": 4,
      "title": "Cache hit ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(snoonu_mcp_cache_hits_total[5m])) / (sum(rate(snoonu_mcp_cache_hits_total[5m])) + sum(rate(snoonu_mcp_cache_misses_total[5m])))", "legendFormat": "hit ratio" }
      ]
    },
    {
      "id": 5,
      "title": "DB pool usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "snoonu_mcp_db_pool_checked_out", "legendFormat": "checked out" },
        { "expr": "snoonu_mcp_db_pool_size", "legendFormat": "pool size" }
      ]
    },
    {
      "id": 6,
      "title": "Orders created vs rate-limited",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "rate(snoonu_mcp_orders_created_total[5m])", "legendFormat": "created" },
        { "expr": "rate(snoonu_mcp_orders_rate_limited_total[5m])", "legendFormat": "rate-limited" }
      ]
    }
  ]
}
